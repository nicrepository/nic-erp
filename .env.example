# ============================================================
# NIC-ERP — Variaveis de Ambiente Obrigatorias
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositorio.
# ============================================================

# Perfil ativo do Spring Boot
# Use "dev" para desenvolvimento local, "prod" para producao
SPRING_PROFILES_ACTIVE=dev

# ----------------------------------------
# BANCO DE DADOS
# ----------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nicerp_db
SPRING_DATASOURCE_USERNAME=nicerp_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# ----------------------------------------
# JWT (OBRIGATORIO — minimo 32 caracteres)
# ----------------------------------------
JWT_SECRET=CHANGE_ME_use_a_long_random_string_here

# ----------------------------------------
# ADMIN SEED (OBRIGATORIO — senha do primeiro admin)
# ----------------------------------------
ADMIN_SEED_NAME=Administrador
ADMIN_SEED_EMAIL=admin@nic-labs.com
ADMIN_SEED_PASSWORD=CHANGE_ME

# ----------------------------------------
# E-MAIL SMTP (OBRIGATORIO em producao)
# ----------------------------------------
SPRING_MAIL_USERNAME=noreply@sua-empresa.com
SPRING_MAIL_PASSWORD=CHANGE_ME

# ----------------------------------------
# UPLOAD DE ARQUIVOS
# ----------------------------------------
FILE_UPLOAD_DIR=/opt/nic-erp/uploads
