# --- PostgreSQL (usado pelo container erp_db) ---
POSTGRES_DB=nicerp_db
POSTGRES_USER=nicerp_user
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# --- Spring Boot: Banco de Dados ---
# A URL aponta para o container erp_db dentro da rede Docker
SPRING_DATASOURCE_URL=jdbc:postgresql://erp_db:5432/nicerp_db
SPRING_DATASOURCE_USERNAME=nicerp_user
SPRING_DATASOURCE_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# --- Spring Boot: JWT ---
# Use um valor aleatório longo (ex: openssl rand -hex 32)
# ATENÇÃO: Renomeado de API_SECURITY_TOKEN_SECRET para NIC_ERP_JWT_SECRET para evitar
#          conflito com Spring Boot relaxed binding (API_SECURITY_TOKEN_SECRET sobrescrevia
#          a propriedade api.security.token.secret diretamente).
NIC_ERP_JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_E_ALEATORIO_MIN_32_CHARS

# --- Spring Boot: E-mail SMTP ---
SPRING_MAIL_USERNAME=email-da-empresa@gmail.com
SPRING_MAIL_PASSWORD=senha-de-app-de-16-letras

# --- Spring Boot: Upload de arquivos ---
# Caminho dentro do container mapeado para o volume erp_uploads
FILE_UPLOAD_DIR=/app/uploads

# --- URL do Frontend (usada no link de recuperação de senha) ---
# Em produção, defina como a URL pública da aplicação.
APP_FRONTEND_URL=https://hub.nic-labs.com

# --- Usuário Administrador inicial ---
# Criado automaticamente no primeiro boot se o banco estiver vazio.
# TROQUE IMEDIATAMENTE após o primeiro login.
ADMIN_SEED_NAME=Administrador
ADMIN_SEED_EMAIL=admin@nic-labs.com
ADMIN_SEED_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
